    given-names: Ronald G.
    orcid: "https://orcid.org/0000-0003-1686-4965"
    email: rgthomas@ucsd.edu
    affiliation: University of California San Diego
keywords:
  - reproducible-research
  - docker
  - renv
  - research-compendium
  - computational-reproducibility
  - collaboration
